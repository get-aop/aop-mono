# Devsfactory Configuration
# Copy this file to .env and adjust as needed

# Directory containing task definitions
DEVSFACTORY_DIR=.devsfactory

# Directory for git worktrees
WORKTREES_DIR=.worktrees

# Maximum number of concurrent agents (global limit across all types)
MAX_CONCURRENT_AGENTS=2

# Debounce delay for file watcher (milliseconds)
DEBOUNCE_MS=100

# Retry backoff configuration for failed agents
RETRY_INITIAL_MS=2000
RETRY_MAX_MS=300000
