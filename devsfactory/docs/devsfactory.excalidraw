    {
      "id": "rdSJcwFaDRI3DTMhsjSp1",
      "type": "text",
      "x": -2639.981128360039,
      "y": 2133.354006737223,
      "width": 530.1597290039062,
      "height": 375,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Z",
      "roundness": null,
      "seed": 374191118,
      "version": 1261,
      "versionNonce": 332039886,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769374341100,
      "link": null,
      "locked": false,
      "text": "in progress issue:\n1. /CLAUDE breakdown the issue in small tasks\nat issue-xxxx-tasks.md set status to in-progress\n2. (NODE) for each task:\n  /CLAUDE loop clear claude window\n  a. get next task available at \n   issue-xxxx-tasks.md \n    IF NO TASKS, SET ISSUE-TASKS.md to REVIEW\n  b. implementing it using TDD (build & test)\n  c. run code-simplifier \n  d. run code-reviewer and add any issues as subtasks\n    IF STUCK CHANGE ISSUE STATUS TO BLOCKED\n  e. if there are no substasks, mark the task done\n  and commit\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "in progress issue:\n1. /CLAUDE breakdown the issue in small tasks\nat issue-xxxx-tasks.md set status to in-progress\n2. (NODE) for each task:\n  /CLAUDE loop clear claude window\n  a. get next task available at \n   issue-xxxx-tasks.md \n    IF NO TASKS, SET ISSUE-TASKS.md to REVIEW\n  b. implementing it using TDD (build & test)\n  c. run code-simplifier \n  d. run code-reviewer and add any issues as subtasks\n    IF STUCK CHANGE ISSUE STATUS TO BLOCKED\n  e. if there are no substasks, mark the task done\n  and commit\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Visdq2_xdKeJ4j1xcFkVH",
      "type": "text",
      "x": -2911.6265108992216,
      "y": 1306.4849365818832,
      "width": 673.01953125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
