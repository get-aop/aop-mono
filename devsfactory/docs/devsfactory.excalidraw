      "seed": 1479059086,
      "version": 603,
      "versionNonce": 595002578,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769373565494,
      "link": null,
      "locked": false,
      "text": "human interactions:\n1. drafting issue = capturing a need/feature, overall description\n2. issue plan = detailed requirements, technical overview \n(can be done while drafting or deferred to later)\n3. issue review = qa; option a) done! open a pr; or b) back to pending",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "human interactions:\n1. drafting issue = capturing a need/feature, overall description\n2. issue plan = detailed requirements, technical overview \n(can be done while drafting or deferred to later)\n3. issue review = qa; option a) done! open a pr; or b) back to pending",
      "autoResize": true,
      "lineHeight": 1.25
    },
