{
  "name": "aop",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "aop": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run ./src/cli.ts",
    "test": "bun test",
    "test:e2e": "bun test ./e2e-tests",
    "test:e2e:orchestrator": "bun test ./e2e-tests/orchestrator.e2e.test.ts",
    "test:e2e:simple": "bun test ./e2e-tests/simple-flow.e2e.test.ts",
    "test:e2e:agentrunner": "bun test ./e2e-tests/agent-runner.e2e.test.ts",
    "test:e2e:git-worktree": "bun test ./e2e-tests/git-worktree.e2e.test.ts",
    "test:e2e:ui": "bunx playwright test --config=./e2e-tests/ui/playwright.config.ts",
    "test:e2e:ui:headed": "bunx playwright test --config=./e2e-tests/ui/playwright.config.ts --headed",
    "test:e2e:ui:debug": "bunx playwright test --config=./e2e-tests/ui/playwright.config.ts --debug",
    "build": "bun build ./src/index.ts --outdir ./dist",
    "lint": "bunx @biomejs/biome check ./src",
    "lint:fix": "bunx @biomejs/biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@happy-dom/global-registrator": "^20.3.9",
    "@playwright/test": "^1.58.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.3.9",
    "lefthook": "^1.11.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@logtape/logtape": "^2.0.2",
    "@logtape/pretty": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@opentui/core": "^0.1.75",
    "@opentui/react": "^0.1.75",
    "ksuid": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.5"
  }
}
