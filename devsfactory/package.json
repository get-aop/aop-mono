  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.75",
    "@opentui/react": "^0.1.75",
    "react": "^19.2.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  }
}
