{
  "name": "@aop/e2e-tests",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "test:e2e": "bun test --concurrency 1 ./src/*.e2e.ts",
    "test:e2e:codex-benchmark": "bun run ../scripts/run-codex-e2e-benchmark.ts",
    "benchmark:codex:aop": "bun run ../scripts/run-aop-codex-benchmark.ts",
    "benchmark:codex:pure": "bun run ../scripts/run-pure-codex-benchmark.ts",
    "benchmark:codex:compare": "bun run ../scripts/compare-codex-benchmarks.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aop/cli": "workspace:*",
    "@aop/common": "workspace:*",
    "@aop/infra": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^1.30.0",
    "playwright": "^1.58.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.9.3"
  }
}
