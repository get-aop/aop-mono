{
  "name": "@aop/local-server",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/run.ts",
    "./server": "./src/server.ts",
    "./context": "./src/context.ts",
    "./db": "./src/db/connection.ts",
    "./db/migrations": "./src/db/migrations.ts",
    "./db/schema": "./src/db/schema.ts",
    "./settings/types": "./src/settings/types.ts"
  },
  "scripts": {
    "build": "bun build ./src/run.ts --outdir ./dist --target bun",
    "build:sidecar": "bun build ./src/run.ts --compile --outfile ./dist/aop-server",
    "dev": "bun run --watch ./src/run.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aop/common": "workspace:*",
    "@aop/git-manager": "workspace:*",
    "@aop/infra": "workspace:*",
    "@aop/llm-provider": "workspace:*",
    "@hono/otel": "^0.3.0",
    "handlebars": "^4.7.8",
    "hono": "^4.11.7",
    "kysely": "^0.28.2",
    "kysely-bun-sqlite": "^0.3.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.9.3"
  }
}
