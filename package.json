{
  "name": "aop",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "bin": {
    "aop": "./apps/cli/src/main.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts",
    "e2e-tests"
  ],
  "scripts": {
    "build": "bun run --sequential --filter '*' build",
    "build:dashboard": "bun run --filter @aop/dashboard build",
    "dev": "bun run ./scripts/dev.ts",
    "dev:dashboard": "bun run --filter @aop/dashboard dev",
    "dev:workspaces": "bun run --filter '*' dev",
    "setup:source": "bun run ./scripts/source-install.ts",
    "test": "bun test",
    "test:ci": "bun test apps packages scripts",
    "test:e2e": "bun test --concurrency 1 ./e2e-tests/src/*.e2e.ts",
    "test:e2e:codex-benchmark": "bun run ./scripts/run-codex-e2e-benchmark.ts",
    "benchmark:codex:aop": "bun run ./scripts/run-aop-codex-benchmark.ts",
    "benchmark:codex:pure": "bun run ./scripts/run-pure-codex-benchmark.ts",
    "benchmark:codex:compare": "bun run ./scripts/compare-codex-benchmarks.ts",
    "test:coverage": "bun test --coverage apps packages scripts",
    "typecheck": "bun run --filter '*' typecheck",
    "check": "bun run lint && bun run typecheck && bun run build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "ralph-loop": "bun run ./scripts/ralph-loop.ts",
    "build:release": "bun run ./scripts/installer/build.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/bun": "^1.3.8",
    "happy-dom": "^20.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "yaml": "^2.8.2"
  }
}
