{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:golangci-lint.run)",
      "WebFetch(domain:revive.run)",
      "Read(~/.claude/**)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "Bash(~/.claude/skills/dex/dex:*)",
      "Bash(docker:*)",
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(git:*)",
      "Bash(gh api:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(sort:*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mpv --ao=pulse --no-video --really-quiet ~/.claude/songs/ping.mp3"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "slack@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "linear@claude-plugins-official": false,
    "code-review@claude-plugins-official": false
  }
}