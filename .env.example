# AOP Port Configuration (what port to bind)
AOP_SERVER_PORT=25101
AOP_LOCAL_SERVER_PORT=25150
AOP_DASHBOARD_PORT=25160

# AOP URL Configuration (how to reach services - can differ in prod behind proxy)
AOP_SERVER_URL=http://localhost:25101
AOP_LOCAL_SERVER_URL=http://localhost:25150
AOP_DASHBOARD_URL=http://localhost:25160

# Database connection string (test DB is auto-derived by appending _test)
AOP_DATABASE_URL=postgresql://aop:aop@localhost:25432/aop
