{
  "name": "aop",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "aop": "./apps/cli/src/main.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts",
    "e2e-tests"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "build:dashboard": "bun run --filter @aop/dashboard build",
    "dev": "bun run ./scripts/dev.ts",
    "dev:dashboard": "bun run --filter @aop/dashboard dev",
    "dev:workspaces": "bun run --filter '*' dev",
    "test": "bun test --env-file .env.test",
    "test:e2e": "bun test --concurrency 1 ./e2e-tests/src/*.e2e.ts",
    "test:coverage": "bun test --coverage --env-file .env.test apps packages scripts",
    "typecheck": "bun run --filter '*' typecheck",
    "check": "bun run lint && bun run typecheck && bun run build",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "lefthook install",
    "ralph-loop": "bun run ./scripts/ralph-loop.ts",
    "build:release": "bun run ./scripts/installer/build.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/bun": "^1.3.8",
    "lefthook": "^2.0.16",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "cac": "^6.7.14"
  }
}
